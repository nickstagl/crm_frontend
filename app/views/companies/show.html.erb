<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Bootstrap demo</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
  </head>
  <body class="container">
    <h1><%= @company["name"] %></h1>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>

    <div class="container text-center">
      <div class="row">

        <%# --- Column 1: Contacts --- %>
        <div class="col">
          <h3>Contacts</h3>

          <ul>
            <% for contact in @contacts %>
              <li>
                <a href="/contacts/<%= contact["id"] %>">
                  <%= contact["last_name"] %>, <%= contact["first_name"] %>
                </a>
              </li>
            <% end %>
          </ul>

          <p>
            <a href="/contacts/new?company_id=<%= @company["id"] %>">New Contact</a>
          </p>
        </div>

        <%# --- Column 2: Sales Activity --- %>
        <div class="col text-start">
          <h4>Sales Activity</h4>

          <ul class="list-unstyled">
            <% for activity in @activities %>
              <% contact = @contacts_by_id[activity["contact_id"]] %>
              <% user    = @users_by_id[activity["user_id"]] %>
              <li class="mb-3">
                <strong>
                  <%= activity["activity_type"] %>
                  between
                  <%= contact ? "#{contact["first_name"]} #{contact["last_name"]}" : "Unknown Contact" %>
                  and
                  <%= user ? "#{user["first_name"]} #{user["last_name"]}" : "Unknown User" %>
                  on
                  <%= activity["created_at"].strftime("%B %-d, %Y") %>
                </strong>
                <% if activity["note"].present? %>
                  <div><%= activity["note"] %></div>
                <% end %>
              </li>
            <% end %>
          </ul>

          <hr>
          <h5>Add Sales Activity</h5>

          <%= form_with url: "/activities", method: :post, local: true do |f| %>
            <%= hidden_field_tag :company_id, @company["id"] %>

            <div class="mb-2">
              <%= label_tag :contact_id, "Contact" %>
              <%= select_tag :contact_id,
                    options_for_select(@contacts.map { |c| ["#{c["last_name"]}, #{c["first_name"]}", c["id"]] }),
                    class: "form-select form-select-sm" %>
            </div>

            <div class="mb-2">
              <%= label_tag :activity_type, "Activity Type" %>
              <%= text_field_tag :activity_type, nil, class: "form-control form-control-sm", placeholder: "e.g. Call, Email, Meeting" %>
            </div>

            <div class="mb-2">
              <%= label_tag :user_id, "Assigned To" %>
              <%= select_tag :user_id,
                    options_for_select(@users.map { |u| ["#{u["first_name"]} #{u["last_name"]}", u["id"]] }),
                    class: "form-select form-select-sm" %>
            </div>

            <div class="mb-2">
              <%= label_tag :note, "Note" %>
              <%= text_area_tag :note, nil, class: "form-control form-control-sm", rows: 3 %>
            </div>

            <button type="submit" class="btn btn-primary btn-sm">Save Activity</button>
          <% end %>
        </div>

      </div>
    </div>
    <button type="button" class="btn btn-outline-primary">
    <a href="/companies">Back to All Companies</a>
    </button>
   

  </body>
</html>
